# AuditLogFactory address on Sepolia (deploy from contracts/ first, paste here)
VITE_FACTORY_ADDRESS=0x8D5B20967e7BFfcd52E7C037Af93BA310C7E3D12

# Default agentId expected from core/. Used for matching in the audit table.
VITE_DEFAULT_AGENT_ID=aye-agent-01

# Sepolia RPC. Optional — wagmi falls back to public RPC if empty.
VITE_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# WalletConnect Cloud project id, required by RainbowKit.
# Create one at https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=YOUR_PROJECT_ID

UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
