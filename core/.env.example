# DeepSeek ---------------------------------------------------------------------
DEEPSEEK_API_KEY=YOUR_API_KEY

# Where the agent posts proposed intents (web/api/intent.ts).
AGENT_API_URL=http://localhost:5173/api/intent

# Where the agent pulls user-submitted commands from (web/api/command.ts).
COMMAND_API_URL=http://localhost:5173/api/command

# How often to poll the command queue (ms). Min 500ms.
COMMAND_POLL_MS=3000

# Logical id reported with each intent (and stored in the on-chain Logged event)
AGENT_ID=aye-agent-01

# Hard cap on LLM calls per UTC day.
DAILY_CALL_LIMIT=500

# How long an unsigned intent stays valid before the EIP-712 deadline expires.
INTENT_DEADLINE_SEC=600
